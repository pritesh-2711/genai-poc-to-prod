# OpenAI API Key (required if using OpenAI provider)
OPENAI_API_KEY=your-openai-api-key-here

# Ollama Configuration (required if using Ollama provider)
# Make sure Ollama is running on this address
# To check the available models, run: curl http://localhost:11434/v1/models
OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-db-name-here
DB_USER=your-db-username-here
DB_PASSWORD=your-db-password-here
